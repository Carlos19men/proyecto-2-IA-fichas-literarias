# ==========================================
# CONFIGURACIÓN DEL ENTORNO LOCAL
# Copia este archivo, renómbralo a '.env' 
# y reemplaza los valores con tus datos reales.
# ==========================================

# --- CONFIGURACIÓN DE LA BASE DE DATOS DE GRAFOS (NEO4J) ---
# URI de conexión (por defecto si usas Docker es bolt://localhost:7687)
NEO4J_URI=bolt://localhost:7687
# Usuario por defecto de Neo4j
NEO4J_USERNAME=neo4j
# Contraseña de la base de datos (Coloca aquí la contraseña real en tu archivo .env)
NEO4J_PASSWORD=tu_contraseña_aqui

# --- CONFIGURACIÓN DE LA IA LOCAL (OLLAMA) ---
# URL donde está corriendo el servidor de Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Nombre exacto del modelo que usarán para razonar y extraer JSON (ej: llama3, mistral)
OLLAMA_MODEL=llama3
# Nombre exacto del modelo de embeddings (ej: nomic-embed-text)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text